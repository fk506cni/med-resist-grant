# ============================================
# Agent Dev Template - .gitignore
# ============================================

# --- 参照資料・アーカイブ (内容はgit管理外) ---
refs/*
!refs/.gitkeep

__archives/*
!__archives/.gitkeep

# N15-05: docs/__archives/ は敵対的レビュー履歴の保存場所として
# git 管理に戻す（共同研究者に履歴を共有、将来の改善 PDCA に活用）。
# 注: 大容量バイナリは __archives/（top-level）に置く運用を継続。

jank/*
!jank/.gitkeep

# --- データ ---
data/source/*
!data/source/.gitkeep
data/output/*
!data/output/.gitkeep
data/products/*
!data/products/.gitkeep
# I15-03: data/original/ は参照用 PDF 等の大容量バイナリの置き場として
# 利用するため git 管理外（用途は CLAUDE.md に追記済）
data/original/

# --- ステップ出力 ---
main/*/output/*
!main/*/output/.gitkeep

# --- 図ビルド成果物 (.mmd はソースとして管理、.svg / .svg.png はビルド生成物) ---
main/step01_narrative/figs/*.svg
main/step01_narrative/figs/*.svg.png

# --- 生成物・一時ファイル ---
*.html
!README.html
*.pyc
*.pyo
__pycache__/
.ipynb_checkpoints/
*.tmp
*.bak
*.swp
*~

# --- OS ---
.DS_Store
Thumbs.db

# --- IDE ---
.idea/
.vscode/
*.code-workspace

# --- Python ---
.venv/
venv/
*.egg-info/
dist/
build/

# --- R ---
.Rhistory
.RData
.Rproj.user/

# --- Docker ---
*.log

# --- パッケージ・アーカイブ ---
*.zip
*.tar.gz

# --- 環境変数 ---
.env
.env.local
.env.*.local

# --- ワークフロー一時ファイル ---
message.md

# --- 開発マーカー ---
.development

# --- Claude Code ローカル設定 (N15-03) ---
# settings.local.json には機微なローカル権限/MCP 設定が含まれる可能性があるため
# 誤コミット防止として除外する
.claude/
