# =============================================================================
# .env.example — collab_watcher.sh 用環境変数テンプレート
# =============================================================================
# このファイルをコピーして .env を作成し、値を記入してください:
#   cp .env.example .env
# .env は .gitignore に含まれており git 管理外です。

# Google Chat Webhook URL（スペースの Webhook から取得）
GCHAT_WEBHOOK_URL=

# rclone リモートとパス（共同執筆用共有フォルダ）
COLLAB_REMOTE="gdrive:"
COLLAB_PATH="share_temp/med-resist-collab"

# 実行環境（docker / uv / direct）
RUNNER="docker"

# ポーリング間隔（秒）
COLLAB_POLL_SEC=15

# クールダウン（前回ビルドからの最低間隔、秒）
COLLAB_COOLDOWN_SEC=120
